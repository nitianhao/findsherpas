## Base
# Public site URL (used for metadata, Stripe success/cancel URLs, sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

## Stripe (one-time Checkout)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

## Contact form (Resend)
RESEND_API_KEY="re_..."
# Where contact submissions should be delivered
CONTACT_TO_EMAIL="hello@findsherpas.com"
# Must be a verified sender in Resend for production
CONTACT_FROM_EMAIL="Find Sherpas <hello@findsherpas.com>"

## Enrichment — email providers (waterfall)
# Absent key = provider disabled (treated as a stub). Hunter is just ONE source.
HUNTER_API_KEY=""
PROSPEO_API_KEY=""        # live — https://www.prospeo.io/api-docs/enrich-person
FINDYMAIL_API_KEY=""      # live — https://app.findymail.com/docs/
DROPCONTACT_API_KEY=""    # live — https://developer.dropcontact.com/
APOLLO_API_KEY=""

## Enrichment — waterfall behaviour (all optional)
# Comma list; default: hunter,prospeo,findymail,dropcontact,apollo,inference
# "inference" is the credit-free last resort (pattern-guess from known examples).
ENRICHMENT_PROVIDER_ORDER="hunter,prospeo,findymail,dropcontact,apollo,inference"
# Allow role inboxes (info@/sales@/support@). Default false.
ENRICHMENT_ALLOW_ROLE_INBOXES="false"
# Which statuses stop the waterfall. Default "verified".
ENRICHMENT_ACCEPT_STATUSES="verified"
# Re-verify an existing CRM email instead of trusting it. Default false.
ENRICHMENT_REVERIFY_EXISTING="false"
# Brave Search API key (used by the website/role discovery pipeline)
BRAVE_SEARCH_API_KEY=""

